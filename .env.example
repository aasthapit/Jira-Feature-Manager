# Copy this file to ".env" and fill in your values.
# ".env" is gitignored and must NEVER be committed.

# Your Jira Cloud site, e.g. https://your-org.atlassian.net
JIRA_BASE_URL=https://your-org.atlassian.net

# The email you log into Jira with
JIRA_EMAIL=you@example.com

# Create one at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-api-token-here

# Which issues to pull. Any valid JQL works.
# Examples:
#   project = FEAT
#   project = FEAT AND statusCategory != Done
#   labels in (frontend, backend) ORDER BY updated DESC
JIRA_JQL=ORDER BY updated DESC

# Optional: cap how many issues to fetch (default 500)
# JIRA_MAX_ISSUES=500
